body
{
	margin: 0px;
	width: 100%;
	height: 100%;
	font-family: sans-serif;
	color: #edf2f7;
	background-color: #07111f;
}

#screen
{
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #07111f;
}

#panel
{
	position: absolute;
	left: 96px;
	top: 92px;
	width: 820px;
	height: 430px;
	padding: 32px;
	background-color: #101827;
	border-width: 1px;
	border-color: #2f3d55;
}

.eyebrow
{
	font-size: 18px;
	color: #38d5c5;
	margin-bottom: 18px;
}

.title
{
	font-size: 56px;
	color: #ffffff;
	margin-bottom: 16px;
}

.subtitle
{
	font-size: 24px;
	color: #aab6c8;
	width: 700px;
	margin-bottom: 34px;
}

.row
{
	margin-bottom: 34px;
}

.stat
{
	display: inline-block;
	width: 330px;
	margin-right: 18px;
	padding: 18px;
	background-color: #172235;
	border-width: 1px;
	border-color: #31415c;
}

.stat-label
{
	font-size: 16px;
	color: #7dd3fc;
	margin-bottom: 8px;
}

.stat-value
{
	font-size: 20px;
	color: #e5edf8;
}

button
{
	width: 260px;
	height: 54px;
	font-size: 20px;
	color: #06131f;
	background-color: #38d5c5;
	border-width: 0px;
}

button:hover
{
	background-color: #67e8f9;
}

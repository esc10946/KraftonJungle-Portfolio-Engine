# ==========================================
# C++ / Visual Studio 관련 무시 파일
# ==========================================

# Visual Studio 기본 캐시 및 사용자 설정 파일
.vs/
*.user
*.suo
*.db
*.opendb
*.VC.db

# ==========================================
# 빌드 결과물 및 중간 생성물 (Intermediate)
# ==========================================

# 빌드 출력 폴더 (x64, Debug, Release 등)
x64/
x86/
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# 현재 프로젝트 특유의 중간 빌드 폴더
Jungle_W.*/

# 컴파일 및 링크 바이너리
*.exe
*.dll
*.obj
*.o
*.pdb
*.idb
*.ilk
*.lib
*.exp

# 빌드 로그 및 임시 파일
*.log
*.tlog
*.lastbuildstate
*.recipe
*.iobj
*.ipdb

# 빌드와 관계 없는 데이터 파일
Data/Scene/*

# ==========================================
# ImGui 및 서드파티 라이브러리 관련
# ==========================================

# ImGui 에디터 레이아웃 설정 파일 (개인마다 다르므로 무시)
imgui.ini

# (선택) 만약 Mac/Linux 환경 팀원이 있다면 추가
.DS_Store


# 특정 라이브러리 포함
!External/Include/DirectXTK/
!External/Library/DirectXTK/**
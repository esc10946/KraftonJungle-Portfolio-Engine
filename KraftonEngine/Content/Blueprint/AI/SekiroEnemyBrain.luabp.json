    {
      "id": 100,
      "type": 217,
      "displayName": "Lua_SelectAttack",
      "nameValue": "Lua_SelectAttack",
      "intValue": 0,
      "floatValue": 0.0,
      "boolValue": false,
      "stringValue": "local function c(fn, ...)\n    if Reflection == nil or obj == nil then return nil end\n    return Reflection.Call(obj, fn, ...)\nend\nlocal function clamp(v, lo, hi)\n    if v < lo then return lo end\n    if v > hi then return hi end\n    return v\nend\nlocal function valid_name(v)\n    local s = tostring(v or '')\n    return s ~= '' and s ~= 'None'\nend\nlocal function range_curve(d, a, b)\n    local span = math.max(1.0, (b or 0) - (a or 0))\n    local t = clamp((d - (a or 0)) / span, 0.0, 1.0)\n    return 1.0 - 0.6 * math.abs(t - 0.5) * 2.0\nend\nlocal function angle_curve(a, limit)\n    limit = math.max(1.0, limit or 70.0)\n    return 1.0 - 0.7 * clamp(a / limit, 0.0, 1.0)\nend\nlocal distance = c('Brain_GetDistance') or 9999.0\nlocal angle = c('Brain_GetAbsAngle') or 180.0\nlocal phase = c('Brain_GetPhase') or 1\nlocal posture = c('Brain_GetTargetPostureRatio') or 1.0\nlocal recovery = c('Brain_TargetInRecovery') == true\nlocal threatening = c('Brain_TargetThreatening') == true\nlocal see = c('Brain_CanSeeTarget') == true\nlocal los = c('Brain_HasLineOfSight') == true\nlocal prox = c('Brain_IsInProximity') == true\nlocal perceptual = ((see and los) or prox) and 1.0 or 0.0\nlocal count = c('Brain_GetAttackCount') or 0\nlocal bestName = nil\nlocal bestScore = -1.0\nc('Brain_BeginDecisionTrace')\nfor i = 0, count - 1 do\n    if c('Brain_CanUseAttackIndex', i) == true then\n        local needPrev = c('Brain_AttackRequiresPreviousAttack', i) == true\n        local prevOk = true\n        if needPrev then\n            prevOk = tostring(c('Brain_GetAttackRequiredPreviousAttack', i) or '') == tostring(c('Brain_GetLastAttackName') or '')\n        end\n        if prevOk then\n            local name = c('Brain_GetAttackName', i)\n            local tactic = tostring(c('Brain_GetAttackTacticTag', i) or 'Neutral'):gsub('_',''):gsub('%s+',''):lower()\n            local isGap = c('Brain_IsAttackGapCloser', i) == true\n            local score = math.max(0.0001, c('Brain_GetAttackBaseWeight', i) or 0.0)\n                * math.max(0.1, c('Brain_GetAttackPriority', i) or 1.0)\n                * range_curve(distance, c('Brain_GetAttackMinRange', i) or 0.0, c('Brain_GetAttackMaxRange', i) or 1.0)\n                * angle_curve(angle, c('Brain_GetAttackMaxAbsAngle', i) or 70.0)\n                * math.pow(clamp(c('Brain_GetAttackRepeatWeightScale', i) or 1.0, 0.0, 1.0), c('Brain_GetRecentAttackRepeat', name) or 0)\n                * perceptual\n            if tactic == 'pressure' then score = score * 1.25 end\n            if tactic == 'combo' and valid_name(c('Brain_GetLastAttackName')) then score = score * 1.45 end\n            if tactic == 'gapcloser' or isGap then score = score * 1.20 end\n            if tactic == 'punish' and recovery then score = score * 1.65 end\n            if threatening and (tactic == 'punish' or tactic == 'retreat') then score = score * 1.25 end\n            if posture > 0.0 and posture < 0.4 and (tactic == 'pressure' or tactic == 'combo') then score = score * 1.35 end\n            if phase >= 2 and (tactic == 'pressure' or tactic == 'gapcloser' or tactic == 'phasechange' or isGap) then score = score * (1.0 + 0.12 * (phase - 1)) end\n            score = score * (0.92 + math.random() * 0.16)\n            c('Brain_AddDecisionCandidate', name, score)\n            if score > bestScore then\n                bestScore = score\n                bestName = name\n            end\n        end\n    end\nend\nif bestName ~= nil and bestScore > 0.05 and c('Brain_SetSelectedAttack', bestName) == true then\n    c('Brain_CommitDecisionTrace', bestName)\n    return true\nend\nc('Brain_CommitDecisionTrace', 'None')\nreturn false",

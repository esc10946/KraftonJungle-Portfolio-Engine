body
{
    width: 100%;
    height: 100%;
    margin: 0px;
    background-color: transparent;
    font-family: "Malgun Gothic";
    font-size: 18px;
    color: rgb(235, 241, 247);
}

#rml-test-panel
{
    position: absolute;
    left: 32px;
    top: 32px;
    width: 260px;
    height: 72px;
    background-color: rgba(40, 180, 255, 170);
    border-width: 2px;
    border-color: rgba(255, 255, 255, 170);
    padding: 10px;
}

#rml-test-accent
{
    position: absolute;
    left: 44px;
    top: 116px;
    width: 180px;
    height: 8px;
    background-color: rgba(255, 120, 40, 220);
}

#rml-test-title
{
    font-size: 20px;
    margin-bottom: 8px;
}

#rml-test-input
{
    width: 210px;
    height: 24px;
    padding: 3px 6px;
    background-color: rgba(10, 16, 24, 210);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 140);
    color: rgb(255, 255, 255);
}

body
{
    width: 100%;
    height: 100%;
    margin: 0px;
    background-color: transparent;
    font-family: "Nexon Lv1 Gothic";
    font-weight: normal;
    font-size: 20px;
    color: rgb(238, 242, 247);
}

.screen-root
{
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
}

.loading-screen
{
    background-color: rgb(15, 18, 22);
}

.controls-panel
{
    position: absolute;
    left: 466px;
    top: 190px;
    width: 860px;
    min-height: 610px;
    padding: 52px 62px;
    decorator: image("Asset/UIImage/ScoreBoardPanel.PNG" fill);
    text-align: center;
}

.panel-title
{
    position: absolute;
    left: 92px;
    top: 70px;
    width: 320px;
    height: 50px;
    margin-bottom: 0px;
    font-size: 38px;
    font-weight: bold;
    color: rgb(255, 224, 154);
    text-align: left;
}

.controls-list
{
    position: absolute;
    left: 92px;
    top: 150px;
    width: 700px;
    margin-left: 0px;
    margin-top: 0px;
}

.control-row
{
    display: block;
    width: 700px;
    height: 42px;
    margin-bottom: 8px;
    font-size: 21px;
}

.control-key
{
    display: inline-block;
    width: 500px;
    height: 34px;
    padding-top: 4px;
    color: rgb(255, 224, 154);
    font-weight: bold;
    text-align: left;
    vertical-align: top;
}

.control-desc
{
    display: inline-block;
    width: 150px;
    height: 34px;
    padding-top: 4px;
    color: rgb(238, 242, 247);
    font-weight: bold;
    text-align: left;
    vertical-align: top;
    margin-right: 24px;
}

.rules-title
{
    position: absolute;
    left: 92px;
    top: 378px;
    width: 320px;
    height: 44px;
    font-size: 34px;
    font-weight: bold;
    color: rgb(255, 224, 154);
    text-align: left;
}

.rules-list
{
    position: absolute;
    left: 92px;
    top: 438px;
    width: 700px;
    margin-left: 0px;
    margin-top: 0px;
}

.rule-row
{
    display: block;
    width: 700px;
    height: 42px;
    margin-bottom: 8px;
    font-size: 21px;
}

.rule-desc
{
    display: inline-block;
    width: 150px;
    height: 34px;
    padding-top: 4px;
    margin-right: 24px;
    color: rgb(255, 255, 255);
    font-weight: bold;
    text-align: left;
    vertical-align: top;
}

.rule-text
{
    display: inline-block;
    width: 500px;
    height: 34px;
    padding-top: 4px;
    color: rgb(255, 224, 154);
    text-align: left;
    vertical-align: top;
}

.tips-block
{
    position: absolute;
    left: 490px;
    bottom: 120px;
    width: 940px;
    text-align: center;
}

.tip-line
{
    width: 940px;
    font-size: 26px;
    font-weight: lighter;
    line-height: 36px;
    color: rgb(255, 255, 255);
}

.loading-cycle
{
    position: absolute;
    right: 82px;
    bottom: 58px;
    width: 96px;
    height: 96px;
    transform-origin: 50% 50%;
}

.status-text
{
    position: absolute;
    right: 82px;
    bottom: 84px;
    width: 420px;
    font-size: 24px;
    text-align: right;
    color: rgb(255, 248, 232);
}

-		}
-	}
-
-	if (bUseBlueprint)
-	{
-		if (Script) Script->SetScriptFile(FString());      // raw-lua 두뇌 끄기(중복 구동 방지)
-		if (Bp)     Bp->SetBlueprintPath(BrainBlueprintFile);

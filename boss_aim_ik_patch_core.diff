-        Ops->Resize(ValuePtr, Count);
-        for (size_t Index = 0; Index < Count; ++Index)
-        {
-            sol::object Element = Table[static_cast<int>(Index + 1)];
-            if (!LuaObjectToValue(*Inner, Ops->GetElementPtr(ValuePtr, Index), Element, OutError))

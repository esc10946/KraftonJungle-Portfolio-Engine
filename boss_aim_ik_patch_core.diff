+-- ── 4. 블랙보드(인지 스냅샷) ─────────────────────────────────────────────────
+local function sense()
+    call(obj, "Brain_UpdateAimTarget")
+    local range = call(obj, "Brain_GetAttackRange") or 3.0
+    if range < 0.1 then range = 0.1 end
+    local dist = call(obj, "Brain_GetDistance") or 9999.0
+    local aimPitch = call(obj, "Brain_GetAimPitch") or 0.0
+    local absAimPitch = math.abs(aimPitch)
+    local vertical = call(obj, "Brain_GetVerticalDelta") or 0.0
+    local belowRatio = aimPitch < 0.0 and clamp((-aimPitch) / 75.0, 0.0, 1.0) or 0.0

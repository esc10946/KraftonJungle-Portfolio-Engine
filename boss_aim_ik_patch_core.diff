+AAIController* AEnemyCharacter::GetEnemyAIController() const
+{
+	return GetAIController();
+}
+
+void AEnemyCharacter::MoveToTarget(float Scale)
+{
+	if (!bCanMove || !AIBrainComponent || !AIBrainComponent->HasValidTarget())
+	{
+		return;
+	}
+	const FVector Direction = AIBrainComponent->GetFlatDirectionToTarget();
+	if (!Direction.IsNearlyZero())
+	{
+		AddMovementInput(Direction, Scale);
+	}
+}
+
+void AEnemyCharacter::FaceTarget(float DeltaTime, float OverrideYawRate)
+{
+	if (!bCanRotate || !AIBrainComponent || !AIBrainComponent->HasValidTarget())
+	{
+		return;
+	}
+	const FVector Direction = AIBrainComponent->GetFlatDirectionToTarget();
+	if (Direction.IsNearlyZero())
+	{
+		return;
+	}
+	FRotator Rotation = GetActorRotation();
+	const float TargetYaw = atan2f(Direction.Y, Direction.X) * FMath::RadToDeg;
+	const float Rate = OverrideYawRate > 0.0f ? OverrideYawRate : TurnSpeed;
+	float DeltaYaw = NormalizeDeltaYaw(TargetYaw - Rotation.Yaw);
+	const float MaxStep = Rate * DeltaTime;
+	DeltaYaw = FMath::Clamp(DeltaYaw, -MaxStep, MaxStep);
+	Rotation.Yaw += DeltaYaw;
+	SetActorRotation(Rotation);
+}
+
+FVector AEnemyCharacter::GetAimOriginLocation() const
+{
+	FVector Origin = GetActorLocation();
+	const float HalfHeight = GetActorCapsuleHalfHeight(const_cast<AEnemyCharacter*>(this));
+	if (HalfHeight > 0.0f)
+	{
+		Origin.Z += HalfHeight * AimOriginHeightRatio;
+	}
+	return Origin;
+}
+
+FVector AEnemyCharacter::ResolveTargetAimLocation(AActor* Target) const
+{
+	if (!IsValid(Target))
+	{
+		return GetActorLocation();
+	}
+	FVector AimLocation = Target->GetActorLocation();
+	const float HalfHeight = GetActorCapsuleHalfHeight(Target);
+	if (HalfHeight > 0.0f)
+	{
+		AimLocation.Z += HalfHeight * TargetAimHeightRatio;
+	}
+	return AimLocation;
+}
+
+FVector AEnemyCharacter::GetCurrentAimTargetLocation() const
+{
+	return bHasCurrentAimTarget ? CurrentAimTargetLocation : GetActorLocation();
+}
+
+void AEnemyCharacter::UpdateAimTarget(float DeltaTime)
+{
+	if (!bUseTargetAim || !AIBrainComponent.IsValid() || !AIBrainComponent->HasValidTarget())
+	{
+		bHasCurrentAimTarget = false;
+		CurrentAimAlpha = 0.0f;
+		SetAnimGraphBool(FName("HasAimTarget"), false);
+		SetAnimGraphFloat(FName("AimAlpha"), 0.0f);
+		return;
+	}
+	AActor* Target = AIBrainComponent->GetTarget();
+	if (!IsValid(Target))
+	{
+		bHasCurrentAimTarget = false;
+		CurrentAimAlpha = 0.0f;
+		SetAnimGraphBool(FName("HasAimTarget"), false);
+		SetAnimGraphFloat(FName("AimAlpha"), 0.0f);
+		return;
+	}
+
+	const FVector Origin = GetAimOriginLocation();
+	const FVector AimLocation = ResolveTargetAimLocation(Target);
+	const FVector ToTarget = AimLocation - Origin;
+	const float FlatDistance = sqrtf(ToTarget.X * ToTarget.X + ToTarget.Y * ToTarget.Y);
+	if (FlatDistance <= 0.001f && fabsf(ToTarget.Z) <= 0.001f)
+	{
+		return;
+	}
+
+	float DesiredPitch = atan2f(ToTarget.Z, (std::max)(0.001f, FlatDistance)) * FMath::RadToDeg;
+	DesiredPitch = FMath::Clamp(DesiredPitch, -MaxAimPitchDown, MaxAimPitchUp);
+	const float DesiredYaw = NormalizeDeltaYaw(atan2f(ToTarget.Y, ToTarget.X) * FMath::RadToDeg - GetActorRotation().Yaw);
+	const float BlendAlpha = AimInterpolationSpeed > 0.0f ? FMath::Clamp(DeltaTime * AimInterpolationSpeed, 0.0f, 1.0f) : 1.0f;
+
+	CurrentAimPitchDegrees = FMath::Lerp(CurrentAimPitchDegrees, DesiredPitch, BlendAlpha);
+	const float DeltaAimYaw = NormalizeDeltaYaw(DesiredYaw - CurrentAimYawDegrees);
+	CurrentAimYawDegrees = NormalizeDeltaYaw(CurrentAimYawDegrees + DeltaAimYaw * BlendAlpha);
+	CurrentAimTargetLocation = AimLocation;
+	CurrentAimAlpha = 1.0f;
+	bHasCurrentAimTarget = true;
+
+	SetAnimGraphBool(FName("HasAimTarget"), true);
+	SetAnimGraphFloat(FName("AimPitch"), CurrentAimPitchDegrees);
+	SetAnimGraphFloat(FName("AimYaw"), CurrentAimYawDegrees);
+	SetAnimGraphFloat(FName("AimAlpha"), CurrentAimAlpha);
+	SetAnimGraphFloat(FName("AimTargetX"), CurrentAimTargetLocation.X);
+	SetAnimGraphFloat(FName("AimTargetY"), CurrentAimTargetLocation.Y);
+	SetAnimGraphFloat(FName("AimTargetZ"), CurrentAimTargetLocation.Z);
+}

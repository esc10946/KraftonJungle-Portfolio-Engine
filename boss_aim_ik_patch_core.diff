+                Result["Actor"]     = Hit.HitActor;
+                Result["Component"] = Hit.HitComponent;
+                Result["Location"]  = Hit.WorldHitLocation;
+                Result["Normal"]    = Hit.WorldNormal;
+                Result["Distance"]  = Hit.Distance;
+            }

-void FLuaScriptManager::RegisterLuaHelpers(sol::state& Lua)
-{
-    // 한글 경로 호환 — safe_script_file 은 내부적으로 fopen(UTF-8) 을 쓰므로 ANSI 해석에서
-    // 깨진다. wide ifstream 으로 직접 읽어 safe_script(string) 으로 실행.

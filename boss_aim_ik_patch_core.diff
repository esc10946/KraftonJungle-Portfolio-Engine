+void AEnemyCharacter::Brain_Dodge()
+{
+	StopEnemyMovement();
+	SetRuntimeState(FName("Dodge"));
+	// 타깃 반대로 빠지는 백스텝 — BeginDash 는 양수 스케일이면 타깃을 향하므로 음수를 줘서 멀어진다.
+	if (UCharacterStateMachineComponent* SM = GetStateMachine())

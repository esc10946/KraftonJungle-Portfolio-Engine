--- t 이상이면 1로 부드럽게 상승.
-function Curve.atLeast(x, t, soft)
-    soft = soft or 0.25
-    return Curve.smooth((x - (t - soft)) / soft)
-end
--- t 이하이면 1로 부드럽게 상승(가까울수록↑ 같은 데 사용).
-function Curve.atMost(x, t, soft)

<rml>
    <head>
        <link type="text/rcss" href="Title.rcss"/>
    </head>
    <body>
        <div class="screen-root title-screen">

            <div class="title-mark1">
                <div id="Title.Name.Green" class="title-logo1">CYBER PSYCHO</div>
                <!--
                <div class="title-subtitle">Project Week09 Team03</div>
                 -->
            </div>
            <div class="title-mark2">
                <div id="Title.Name.Red" class="title-logo2">CYBER PSYCHO</div>
                <!--
                <div class="title-subtitle">Project Week09 Team03</div>
                 -->
            </div>
            <div class="title-mark3">
                <div id="Title.Name" class="title-logo3">CYBER PSYCHO</div>
                <!--
                <div class="title-subtitle">Project Week09 Team03</div>
                 -->
            </div>

            <div id="Title.MenuPanel" class="title-panel menu-panel">
                <button id="Title.Start" class="button primary" data-action="StartGame">Game Start</button>
                <button id="Title.Intro" class="button" data-action="ShowIntro">Intro</button>
                <button id="Title.ScoreBoard" class="button" data-action="ShowScoreBoard">Score Board</button>
                <button id="Title.Settings" class="button" data-action="ShowSettings">Settings</button>
                <button id="Title.Credits" class="button" data-action="ShowCredits">Credits</button>
                <button id="Title.Quit" class="button danger" data-action="QuitGame">Quit</button>
            </div>

            <!--
            <div id="Title.ScoreBoardPanel" class="title-panel sub-panel">
                <div class="headline">Score Board</div>
                <div id="Title.BestScore" class="panel-line strong">Best Score: 0</div>
                <button class="button" data-action="BackToTitleMenu">Back</button>
            </div>
            -->
            <!--
            <div id="Title.SettingsPanel" class="title-panel sub-panel">
                <div class="headline">Settings</div>
                <div class="setting-row">
                    <div class="setting-label">BGM</div>
                    <button class="step-button" data-action="BGMDown">-</button>
                    <div id="Title.Settings.BGMValue" class="setting-value">100%</div>
                    <button class="step-button" data-action="BGMUp">+</button>
                </div>
                <div class="setting-row">
                    <div class="setting-label">SFX</div>
                    <button class="step-button" data-action="SFXDown">-</button>
                    <div id="Title.Settings.SFXValue" class="setting-value">100%</div>
                    <button class="step-button" data-action="SFXUp">+</button>
                </div>
                <button class="button" data-action="BackToTitleMenu">Back</button>
            </div>
            -->
            <!--
            <div id="Title.CreditsPanel" class="title-panel sub-panel">
                <div class="headline">Credits</div>
                <div class="panel-line">Management / UI</div>
                <div class="panel-line strong">Game Jam Build</div>
                <button class="button" data-action="BackToTitleMenu">Back</button>
            </div>
            -->
            <div id="Title.Version" class="version-label">Latest Update v.20260504 by Team03</div>
        </div>
    </body>
</rml>

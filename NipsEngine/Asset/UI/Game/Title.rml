<rml>
    <head>
        <link type="text/rcss" href="Title.rcss"/>
    </head>
    <body>
        <div class="screen-root title-screen">
            <div id="Title.Cyber.Mark1" class="title-mark1">
                <div id="Title.Cyber.Logo1" class="title-logo1">CYBER</div>
            </div>
            <div id="Title.Cyber.Mark2" class="title-mark2">
                <div id="Title.Cyber.Logo2" class="title-logo2">CYBER</div>
            </div>
            <div id="Title.Cyber.Mark3" class="title-mark3">
                <div id="Title.Cyber.Logo3" class="title-logo3">CYBER</div>
            </div>

            <div id="Title.Psycho.Mark1" class="title-mark4">
                <div id="Title.Psycho.Logo1" class="title-logo4">PSYCHO</div>
            </div>
            <div id="Title.Psycho.Mark2" class="title-mark5">
                <div id="Title.Psycho.Logo2" class="title-logo5">PSYCHO</div>
            </div>
            <div id="Title.Psycho.Mark3" class="title-mark6">
                <div id="Title.Psycho.Logo3" class="title-logo6">PSYCHO</div>
            </div>

            <div id="Title.MenuPanel" class="menu-panel">
                <button id="Title.Start" class="title-button primary" data-action="StartGame">Game Start</button>
                <button id="Title.ScoreBoard" class="title-button" data-action="ShowScoreBoard">Score Board</button>
                <button id="Title.Quit" class="title-button danger" data-action="QuitGame">Quit</button>
            </div>

            <div id="Title.QuickMenu" class="quick-menu">
                <button id="Title.Intro" class="quick-button" data-action="ShowIntro">
                    <img class="quick-icon" src="Asset/UIImage/58_Talk_3.PNG"/>
                </button>
                <button id="Title.Settings" class="quick-button" data-action="ShowSettings">
                    <img class="quick-icon" src="Asset/UIImage/25_Setting.PNG"/>
                </button>
                <button id="Title.Credits" class="quick-button" data-action="ShowCredits">
                    <img class="quick-icon" src="Asset/UIImage/14_Exclamation.PNG"/>
                </button>
            </div>

            <div id="Title.Version" class="version-label">Latest Update v1.0.0 by Team03</div>

            <div id="Title.ModalOverlay" class="modal-overlay"></div>

            <div id="Title.ScoreBoardPanel" class="title-panel title-sub-panel">
                <div class="panel-title">Score Board</div>
                <div class="scroll-box scoreboard-scroll">
                    <div id="Title.ScoreRows" class="score-list">
                        <div class="score-empty">No Records</div>
                    </div>
                </div>
            </div>

            <div id="Title.SettingsPanel" class="title-panel title-sub-panel settings-panel">
                <div class="settings-backdrop"></div>
                <div class="panel-title">Settings</div>
                <div class="setting-row bgm-setting">
                    <div class="setting-label">BGM</div>
                    <input id="Title.Settings.BGMSlider" class="volume-slider" type="range" min="0" max="100" step="1" value="100" data-action="BGMVolumeChanged"/>
                    <div id="Title.Settings.BGMValue" class="setting-value">100%</div>
                </div>
                <div class="setting-row sfx-setting">
                    <div class="setting-label">SFX</div>
                    <input id="Title.Settings.SFXSlider" class="volume-slider" type="range" min="0" max="100" step="1" value="100" data-action="SFXVolumeChanged"/>
                    <div id="Title.Settings.SFXValue" class="setting-value">100%</div>
                </div>
            </div>


            <div id="Title.CreditsPanel" class="title-panel title-sub-panel credits-panel">
                <div class="credits-backdrop"></div>
                <div class="panel-title">Credits</div>
                <div class="credits-content">
                    <div class="credit-row">
                        <div class="credit-role">Player</div>
                        <div class="credit-name">김지수 (Ji-Soo KIM)</div>
                    </div>
                    <div class="credit-row">
                        <div class="credit-role">Enemy</div>
                        <div class="credit-name">김호준 (Ho-Jun KIM)</div>
                    </div>
                    <div class="credit-row">
                        <div class="credit-role">UI/Manager</div>
                        <div class="credit-name">양현석 (Hyun-Seok YANG)</div>
                    </div>
                    <div class="credit-period">Development Period 20260430-20260504</div>
                    <div class="credit-build">
                        <div>KRAFTON JUNGLE GAMETECHLAB 3기 Week09</div>
                        <div>Team03 GAME JAM</div>
                    </div>
                </div>
            </div>

            <button id="Title.ModalClose" class="panel-close" data-action="BackToTitleMenu">
                <img class="panel-close-icon" src="Asset/UIImage/13_Escape_r.PNG"/>
            </button>
        </div>
    </body>
</rml>

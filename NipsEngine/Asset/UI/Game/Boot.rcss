body
{
    width: 100%;
    height: 100%;
    margin: 0px;
    background-color: transparent;
    font-family: "Malgun Gothic";
    font-size: 20px;
    color: rgb(238, 242, 247);
}

.screen-root
{
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
    background-color: rgb(10, 13, 16);
}

.center-stack
{
    position: absolute;
    left: 710px;
    top: 420px;
    width: 500px;
    height: 116px;
    text-align: center;
}

.boot-bg
{
    position: absolute;
    left: 0px;
    top: 0px;
    width: 500px;
    height: 116px;
}

.headline
{
    position: absolute;
    left: 0px;
    top: 34px;
    width: 500px;
    font-size: 42px;
    color: rgb(255, 248, 232);
}

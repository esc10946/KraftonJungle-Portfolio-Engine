body
{
    width: 100%;
    height: 100%;
    margin: 0px;
    background-color: transparent;
    font-family: "Malgun Gothic";
    font-size: 20px;
    color: rgb(238, 242, 247);
}

.screen-root
{
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
}

.center-stack
{
    position: absolute;
    left: 760px;
    top: 250px;
    width: 400px;
    text-align: center;
}

.headline
{
    margin-bottom: 34px;
    font-size: 42px;
    color: rgb(255, 248, 232);
}
